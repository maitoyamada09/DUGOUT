    "「相手」ボタンからチーム・選手を登録し、\n打順タブで設定してください" : {
      "comment" : "A description below the \"「相手」ボタン\" label, explaining how to set up the opponent lineup.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Register team/players from \"Opponent\" button,\nthen set lineup in the Lineup tab"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registre equipo/jugadores desde \"Rival\",\nluego configure la alineación"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"상대\" 버튼에서 팀/선수를 등록하고\n타순 탭에서 설정해주세요"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从\"对手\"按钮注册球队/球员，\n然后在打序标签中设置"
          }
        }
      }
    },
    "「自動」を選ぶと端末の言語設定に従います。" : {
      "comment" : "A description of the \"Auto\" option in the settings menu, explaining that it will use the device's language settings.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose \"Auto\" to follow device language settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seleccione \"Auto\" para seguir el idioma del dispositivo."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"자동\"을 선택하면 기기 언어 설정을 따릅니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "选择\"自动\"将跟随设备语言设置。"
          }
        }
      }
    },
